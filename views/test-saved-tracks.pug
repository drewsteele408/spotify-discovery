extends layout

block content
	section
		h2 Saved Tracks Test
		p This page shows the result of an authenticated Spotify API request for your liked/saved tracks.
		if apiError
			p #{apiError}

	section
		h3 Saved tracks query parameters
		form(action='/test-saved-tracks', method='GET')
			p
				label(for='limit') limit
				input(type='number', id='limit', name='limit', min='1', max='50', step='1', value=selectedLimit || '')
			p
				button(type='submit') Run Request

	section
		h3 Saved tracks
		if topTracks && topTracks.length
			ol
				each track in topTracks
					li
						p
							strong Track:
							|  #{track.name || 'Not available'}
						p
							strong Artists:
							|  #{track.artists || 'Not available'}
						p
							strong Album:
							|  #{track.album || 'Not available'}
						p
							strong Popularity:
							|  #{track.popularity}
						if track.spotifyUrl
							p
								a(href=track.spotifyUrl, target='_blank', rel='noopener noreferrer') Open in Spotify
		else
			p No saved track data is available yet.

	section
		h3 API response
		if apiData
			pre= JSON.stringify(apiData, null, 2)
		else
			p No protected Spotify API response is available yet.

	section
		p
			a(href='/test-api') Test Top Tracks
		p
			a(href='/test-top-artists') Test Top Artists
		p
			a(href='/dashboard') Return to dashboard
		p
			a(href='/') Return to home
