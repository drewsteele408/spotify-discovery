extends layout

block content
	section
		h2 Protected Spotify API test
		p This page shows the result of an authenticated Spotify API request.
		if apiError
			p #{apiError}

	section
		h3 Top track query parameters
		form(action='/test-api', method='GET')
			p
				label(for='time_range') time_range
				select(name='time_range', id='time_range')
					option(value='') Use Spotify default
					option(value='short_term', selected=selectedTimeRange === 'short_term') short_term
					option(value='medium_term', selected=selectedTimeRange === 'medium_term') medium_term
					option(value='long_term', selected=selectedTimeRange === 'long_term') long_term
			p
				label(for='limit') limit
				input(type='number', id='limit', name='limit', min='1', max='50', step='1', value=selectedLimit || '')
			p
				button(type='submit') Run Request

	section
		if spotifyProfile
			h3 Current user
			ul
				li
					strong Display name:
					|  #{spotifyProfile.display_name || 'Not available'}
				li
					strong Email:
					|  #{spotifyProfile.email || 'Not available'}
				li
					strong Spotify ID:
					|  #{spotifyProfile.id || 'Not available'}
		else
			h3 Current user
			p No Spotify profile data is currently available in the session.

	section
		h3 Top tracks
		if topTracks && topTracks.length
			ol
				each track in topTracks
					li
						p
							strong Track:
							|  #{track.name || 'Not available'}
						p
							strong Artists:
							|  #{track.artists || 'Not available'}
						p
							strong Album:
							|  #{track.album || 'Not available'}
						if track.spotifyUrl
							p
								a(href=track.spotifyUrl, target='_blank', rel='noopener noreferrer') Open in Spotify
						if track.id
							p
								button(type='button', data-track-id=track.id, onclick='getSoundchartsUuid(this)') Get Spotify UUID
							pre(id='uuid-response-' + track.id)
		else
			p No simplified top-track data is available yet.

	section
		h3 API response
		if apiData
			pre= JSON.stringify(apiData, null, 2)
		else
			p No protected Spotify API response is available yet.

	section
		p
			a(href='/test-top-artists') Test Top Artists
		p
			a(href='/test-saved-tracks') Test Saved Tracks
		p
			a(href='/dashboard') Return to dashboard
		p
			a(href='/') Return to home

	script.
		function getSoundchartsUuid(button) {
			var trackId = button.dataset.trackId;
			var responseEl = document.getElementById('uuid-response-' + trackId);
			button.disabled = true;
			button.textContent = 'Loading...';
			if (responseEl) responseEl.textContent = 'Fetching...';
			fetch('/api/soundcharts/song/' + trackId)
				.then(function(res) { return res.json(); })
				.then(function(data) {
					if (responseEl) responseEl.textContent = JSON.stringify(data, null, 2);
					button.textContent = 'Get Spotify UUID';
					button.disabled = false;
				})
				.catch(function(err) {
					if (responseEl) responseEl.textContent = 'Error: ' + err.message;
					button.textContent = 'Get Spotify UUID';
					button.disabled = false;
				});
		}
